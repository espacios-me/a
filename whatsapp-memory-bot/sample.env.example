# Core WhatsApp
ACCESS_TOKEN=example_access_token
APP_SECRET=example_app_secret
VERIFY_TOKEN=example_verify_token
PORT=8080
WHATSAPP_PHONE_NUMBER_ID=example_phone_number_id

# Optional Redis (falls back to in-memory if unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379

# Memory backend
# local | sheets
MEMORY_BACKEND=local
DATA_FILE=./data/store.json

# OpenAI (optional but recommended)
OPENAI_API_KEY=example_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Google Sheets backend (required only when MEMORY_BACKEND=sheets)
GOOGLE_SHEET_ID=example_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account"}

# Reminder cron protection
CRON_SECRET=replace_me

# Optional reminder template for outside the 24h customer window
# REMINDER_TEMPLATE_NAME=atom_reminder
# REMINDER_TEMPLATE_LOCALE=en_US

# Set only for local debugging if webhook signature validation blocks tests
# DISABLE_SIGNATURE_VALIDATION=true
